{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghostdriver.dev/schemas/group.schema.json",
  "title": "GhostDriver experiment group manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "experiment_id",
    "variable_name",
    "variable_value",
    "repetitions",
    "status",
    "runs"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "experiment_id": { "type": "string", "minLength": 1 },
    "variable_name": { "type": "string", "minLength": 1 },
    "variable_value": { "type": "integer", "minimum": 0 },
    "repetitions": { "type": "integer", "minimum": 1 },
    "status": {
      "enum": ["planned", "running", "completed", "failed"]
    },
    "runs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
